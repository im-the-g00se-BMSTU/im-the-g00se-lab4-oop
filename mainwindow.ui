  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background-color: #111111;
	color: #f2f2f2;
}

QGroupBox {
    border: 1px solid #2f2f2f;
    border-radius: 6px;
    margin-top: 18px;
    padding: 8px 6px 6px 6px;
    color: #f2f2f2;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
	top: 10px;
    padding: 0 6px;
    color: #ffffff;
}
QLabel#pathLabel {
    border: 1px solid #2f2f2f;
    border-radius: 4px;
    color: #ffffff;
    padding: 7px 9px;
}
QPushButton {
    background-color: #2a2a2a;
    border: 1px solid #3a3a3a;
    border-radius: 5px;
    color: #f2f2f2;
    min-height: 28px;
    padding: 5px 10px;
}
QPushButton:hover {
    background-color: #333333;
    border-color: #4a4a4a;
}
QPushButton:pressed {
    background-color: #1f1f1f;
}

QPushButton#uploadPushButton {
    background-color: #1f66d1;
    border-color: #2674e8;
    min-height: 34px;
}

QPushButton#uploadPushButton:hover {
    background-color: #2674e8;
}

QDoubleSpinBox {
    background-color: #252525;
    border: 1px solid #303030;
    border-radius: 4px;
    color: #ffffff;
    min-height: 28px;
    padding: 4px 30px 4px 8px;
    selection-background-color: #1f66d1;
}
QDoubleSpinBox:hover {
    border-color: #4a4a4a;
}
QDoubleSpinBox::up-button,
QDoubleSpinBox::down-button {
    subcontrol-origin: border;
    width: 22px;
    right: 3px;
    background-color: #303030;
    border-left: 1px solid #3d3d3d;
}
QDoubleSpinBox::up-button {
    subcontrol-position: top right;
    top: 3px;
    border-top-right-radius: 3px;
}
QDoubleSpinBox::down-button {
    subcontrol-position: bottom right;
    bottom: 3px;
    border-bottom-right-radius: 3px;
}
QDoubleSpinBox::up-button:hover,
QDoubleSpinBox::down-button:hover {
    background-color: #3a3a3a;
}
QDoubleSpinBox::up-button:pressed,
QDoubleSpinBox::down-button:pressed {
    background-color: #1f66d1;
}

QDoubleSpinBox::up-arrow {
    image: url(:/assets/arrow_drop_up.svg);
}
QDoubleSpinBox::down-arrow {
    image: url(:/assets/arrow_drop_down.svg);
}

QGraphicsView#graphicsView {
    border: 1px solid #2b2b2b;
    background-color: #111111;
    border-radius: 6px;
}
QToolTip {
    background-color: #252525;
    border: 1px solid #3a3a3a;
    color: #ffffff;
    padding: 4px;
}</string>
